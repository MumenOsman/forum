{{define "base"}}
<!DOCTYPE html>
<html class="dark" lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>Literary Lions Forum</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,200..800;1,6..72,200..800&family=Manrope:wght@200..800&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "on-error-container": "#ffdad6", "surface-tint": "#9ecaff", "on-background": "#dae2fd",
                        "surface-variant": "#2d3449", "on-secondary-fixed-variant": "#394951", "on-secondary-fixed": "#0d1e25",
                        "primary-fixed": "#d1e4ff", "primary-fixed-dim": "#9ecaff", "inverse-surface": "#dae2fd",
                        "on-primary-container": "#2d9cf9", "outline-variant": "#454652", "surface-container-high": "#222a3d",
                        "surface-container-lowest": "#060e20", "secondary-container": "#3b4b53", "on-tertiary-container": "#c09000",
                        "on-primary": "#003258", "secondary-fixed-dim": "#b8c9d3", "on-primary-fixed": "#001d36",
                        "surface-bright": "#31394d", "inverse-primary": "#0061a4", "tertiary": "#fabd00",
                        "on-tertiary-fixed-variant": "#5b4300", "error": "#ffb4ab", "primary-container": "#003157",
                        "surface-container-low": "#131b2e", "inverse-on-surface": "#283044", "tertiary-fixed": "#ffdf9e",
                        "primary": "#9ecaff", "surface-container-highest": "#2d3449", "surface-container": "#171f33",
                        "on-surface-variant": "#c6c5d4", "on-tertiary": "#3f2e00", "surface-dim": "#0b1326",
                        "secondary": "#b8c9d3", "on-surface": "#dae2fd", "error-container": "#93000a",
                        "tertiary-fixed-dim": "#fabd00", "on-secondary": "#23333a", "secondary-fixed": "#d4e5ef",
                        "tertiary-container": "#3f2d00", "background": "#0b1326", "on-secondary-container": "#aabbc5",
                        "surface": "#0b1326", "on-error": "#690005", "outline": "#908f9d", "on-tertiary-fixed": "#261a00",
                        "on-primary-fixed-variant": "#00497d"
                    },
                    fontFamily: {
                        "headline": ["Newsreader"], "body": ["Manrope"], "label": ["Manrope"]
                    },
                    borderRadius: {"DEFAULT": "0.125rem", "lg": "0.25rem", "xl": "0.5rem", "full": "0.75rem"},
                },
            },
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            display: inline-block;
            line-height: 1;
            text-transform: none;
            letter-spacing: normal;
            word-wrap: normal;
            white-space: nowrap;
            direction: ltr;
        }
        body {
            background-color: #0b1326;
            color: #dae2fd;
            font-family: 'Manrope', sans-serif;
            margin: 0; padding: 0;
        }
        .serif-headline {
            font-family: 'Newsreader', serif;
        }
        .glass-morphism, .glass-panel {
            backdrop-filter: blur(12px) saturate(180%);
            -webkit-backdrop-filter: blur(12px) saturate(180%);
        }
    </style>
</head>
<body class="bg-background text-on-background antialiased overflow-x-hidden min-h-screen flex flex-col selection:bg-primary-container selection:text-primary">

<!-- Universal TopNavBar -->
<nav class="fixed top-0 w-full z-50 bg-[#171f33]/70 backdrop-blur-xl saturate-180 border-b border-[#dae2fd]/15 shadow-[0_20px_40px_rgba(0,0,0,0.3)]">
    <div class="flex justify-between items-center w-full px-8 py-4 mx-auto max-w-screen-2xl">
        <div class="flex items-center gap-8">
            <a href="/" class="text-2xl font-serif italic text-[#fabd00] serif-headline no-underline hover:brightness-125 transition-all">Literary Lions Forum</a>
        </div>
        <div class="flex items-center gap-4">
            {{if .IsAuthenticated}}
                <a href="/post/create" class="px-5 py-2 text-sm font-bold text-tertiary border border-tertiary/50 rounded-md hover:bg-tertiary/10 transition-all no-underline">Create Post</a>
                <form action="/user/logout" method="POST" class="m-0 p-0">
                    <button type="submit" class="px-5 py-2 text-sm font-bold text-[#f87171] hover:text-[#fca5a5] hover:bg-[#f87171]/10 rounded-md transition-all">Logout</button>
                </form>
            {{else}}
                <a href="/user/login" class="px-5 py-2 text-sm font-bold text-[#dae2fd]/70 hover:text-[#dae2fd] transition-all no-underline">Login</a>
                <a href="/user/signup" class="px-5 py-2 text-sm font-bold bg-primary text-on-primary rounded-md hover:opacity-90 transition-all active:scale-95 duration-200 no-underline shadow-lg hover:shadow-primary/20">Register</a>
            {{end}}
        </div>
    </div>
</nav>

<!-- Inject specific page content here -->
{{template "main" .}}

</body>
</html>
{{end}}
