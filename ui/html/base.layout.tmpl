{{define "base"}}
<!doctype html>
<html lang='en'>
    <head>
        <meta charset='utf-8'>
        <title>Literary Lions Forum</title>
        <link rel='stylesheet' href='/static/css/style.css'>
    </head>
    <body>
        <header>
            <h1><a href='/'>Literary Lions Forum</a></h1>
        </header>
        <nav>
            <a href='/'>Home</a>
            {{if .IsAuthenticated}}
                <a href='/post/create'>Create Post</a>
                <form action='/user/logout' method='POST'>
                    <button>Logout</button>
                </form>
            {{else}}
                <a href='/user/signup'>Signup</a>
                <a href='/user/login'>Login</a>
            {{end}}
        </nav>
        <main>
            {{template "main" .}}
        </main>
        <footer>
            Powered by Go in {{.CurrentYear}}
        </footer>
    </body>
</html>
{{end}}
