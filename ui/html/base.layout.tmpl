{{define "base"}}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{template "title" .}} - Literary Lions Forum</title>
    <link rel="stylesheet" href="/static/css/style.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
    <header>
        <a href="/" class="logo">🦁 Literary Lions</a>
        <nav>
            <ul>
                <li><a href="/">Home</a></li>
                {{if .IsAuthenticated}}
                    <li><a href="/post/create">New Post</a></li>
                    <li><a href="/user/profile">Profile</a></li>
                    <li>
                        <form action="/user/logout" method="POST" style="display:inline;">
                            <button type="submit" class="btn btn-secondary">Logout</button>
                        </form>
                    </li>
                {{else}}
                    <li><a href="/user/login">Login</a></li>
                    <li><a href="/user/register">Register</a></li>
                {{end}}
            </ul>
        </nav>
    </header>

    <main>
        {{template "main" .}}
    </main>

    <footer>
        <p>&copy; {{.Year}} Literary Lions Book Club. All rights reserved.</p>
    </footer>

    <script src="/static/js/main.js"></script>
</body>
</html>
{{end}}
