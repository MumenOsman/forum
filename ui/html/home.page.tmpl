{{template "base" .}}

{{define "main"}}
<div class="forum-container">
    <!-- Sidebar for Filters -->
    <aside class="sidebar">
        <div style="margin-bottom: 20px;">
            <h3>Search</h3>
            <form action="/" method="GET" style="display: flex; gap: 5px; flex-direction: column;">
                <input type="text" name="q" placeholder="Keywords..." required style="padding: 8px; border: 1px solid var(--border-color); border-radius: 4px;">
                <button type="submit" class="btn btn-primary" style="padding: 8px;">Find Topics</button>
            </form>
        </div>

        <div>
            <h3>Explore</h3>
            <ul>
                <li><a href="/">All Discussions</a></li>
                {{if $.IsAuthenticated}}
                <li><a href="/?authored=true">My Posts</a></li>
                <li><a href="/?liked=true">Liked by Me</a></li>
                {{end}}
            </ul>
        </div>

        <div>
            <h3>Categories</h3>
            <ul>
            {{range .Categories}}
                <li><a href="/?category={{.ID}}">{{.Name}}</a></li>
            {{end}}
            </ul>
        </div>
    </aside>

    <!-- Main Feed -->
    <section class="feed">
        <h2>Latest Conversations</h2>
        {{if .Posts}}
            <div class="post-list">
            {{range .Posts}}
                <article class="post-card">
                    <a href="/post/view?id={{.ID}}">{{.Title}}</a>
                    <div class="post-meta">
                        by <a href="/user/profile?id={{.UserID}}" style="color: var(--accent-light); text-decoration: none;"><strong>{{.Username}}</strong></a> • {{.CreatedAt.Format "Jan 02, 2006"}}
                    </div>
                    <div class="post-content-preview" style="font-size: 0.9375rem; color: var(--text-main); margin-bottom: 1rem; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; text-overflow: ellipsis;">
                        {{.Content}}
                    </div>
                    <div class="post-stats">
                        <span>💬 {{.CommentCount}} comments</span>
                        <div class="vote-controls">
                            <span title="Likes">👍 {{.Likes}}</span>
                            <span title="Dislikes">👎 {{.Dislikes}}</span>
                        </div>
                        {{if $.IsAuthenticated}}
                        <form action="/vote" method="POST" style="display:inline;">
                            <input type="hidden" name="target_id" value="{{.ID}}">
                            <input type="hidden" name="target_type" value="post">
                            <button type="submit" name="vote_type" value="1" class="vote-btn">👍</button>
                            <button type="submit" name="vote_type" value="-1" class="vote-btn">👎</button>
                        </form>
                        {{end}}
                    </div>
                </article>
            {{end}}
            </div>
        {{else}}
            <div class="glass" style="padding: 2rem; border-radius: var(--radius); text-align: center;">
                <p>No posts found. Why not start a new discussion?</p>
                {{if .IsAuthenticated}}
                <a href="/post/create" class="btn btn-primary" style="margin-top: 1rem;">Create First Post</a>
                {{end}}
            </div>
        {{end}}
    </section>
</div>
{{end}}
