{{template "base" .}}

{{define "main"}}
<h2>Latest Posts</h2>
{{if .Posts}}
    <ul>
    {{range .Posts}}
        <li>
            <a href="/post/view?id={{.ID}}"><strong>{{.Title}}</strong></a> by {{.Username}}
            <p>Likes: {{.Likes}} | Dislikes: {{.Dislikes}} | Comments: {{.CommentCount}}</p>
        </li>
    {{end}}
    </ul>
{{else}}
    <p>No posts yet! Be the first to start a discussion.</p>
{{end}}
{{end}}
