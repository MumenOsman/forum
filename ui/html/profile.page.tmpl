{{template "base" .}}

{{define "main"}}
<div class="profile-container" style="max-width: 800px; margin: 0 auto; padding: 20px;">
    <!-- Profile Header -->
    <div class="glass profile-header" style="padding: 30px; border-radius: var(--radius); margin-bottom: 2rem; display: flex; align-items: center; gap: 20px; background: rgba(255, 255, 255, 0.05); border: 1px solid var(--border-color);">
        <div class="profile-avatar" style="width: 80px; height: 80px; border-radius: 50%; background: var(--bg-secondary); display: flex; align-items: center; justify-content: center; font-size: 2rem; color: var(--accent-light);">
            👤
        </div>
        <div>
            <h2 style="margin: 0 0 10px 0; color: var(--text-main); font-size: 2rem;">{{.User.Username}}'s Profile</h2>
            <p style="margin: 0; color: var(--text-muted); display: flex; align-items: center; gap: 8px;">
                <span>📅 Joined: {{.User.CreatedAt}}</span>
            </p>
        </div>
    </div>

    <!-- User's Posts Feed -->
    <div class="profile-posts section">
        <h3 style="margin-bottom: 1.5rem; color: var(--text-main); border-bottom: 2px solid var(--accent-color); padding-bottom: 0.5rem; display: inline-block;">Authored Posts</h3>
        
        {{if .Posts}}
            <div class="post-list" style="display: flex; flex-direction: column; gap: 1rem;">
            {{range .Posts}}
                <article class="post-card glass" style="padding: 1.5rem; border-radius: var(--radius); transition: transform 0.2s ease;">
                    <a href="/post/view?id={{.ID}}" style="font-size: 1.25rem; font-weight: bold; color: var(--accent-light); text-decoration: none; display: block; margin-bottom: 0.5rem;">{{.Title}}</a>
                    
                    <div class="post-meta" style="font-size: 0.875rem; color: var(--text-muted); margin-bottom: 1rem;">
                        Posted on {{.CreatedAt.Format "Jan 02, 2006 at 15:04"}}
                    </div>
                    
                    <div class="post-content-preview" style="font-size: 0.9375rem; color: var(--text-main); margin-bottom: 1rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; text-overflow: ellipsis;">
                        {{.Content}}
                    </div>
                    
                    <div class="post-stats" style="display: flex; justify-content: space-between; align-items: center; border-top: 1px solid var(--border-color); padding-top: 1rem; font-size: 0.875rem;">
                        <span style="color: var(--text-muted);">💬 {{.CommentCount}} comments</span>
                        <div class="vote-controls" style="display: flex; gap: 15px; background: rgba(0,0,0,0.2); padding: 5px 15px; border-radius: 20px;">
                            <span title="Likes" style="color: #4ade80;">👍 {{.Likes}}</span>
                            <span title="Dislikes" style="color: #f87171;">👎 {{.Dislikes}}</span>
                        </div>
                    </div>
                </article>
            {{end}}
            </div>
        {{else}}
            <div class="glass empty-state" style="padding: 3rem 2rem; border-radius: var(--radius); text-align: center; border: 1px dashed var(--border-color);">
                <div style="font-size: 3rem; margin-bottom: 1rem; opacity: 0.5;">📝</div>
                <p style="color: var(--text-muted); font-size: 1.1rem; margin: 0;">This user hasn't sparked any conversations yet.</p>
            </div>
        {{end}}
    </div>
</div>
{{end}}
