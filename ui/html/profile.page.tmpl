{{template "base" .}}

{{define "main"}}
<div class="flex min-h-screen pt-20 w-full">
    <!-- SideNavBar Component -->
    <aside class="h-full w-64 fixed left-0 top-0 pt-20 flex flex-col p-4 space-y-2 sidebar-bg z-40 hidden lg:flex overflow-y-auto">
        {{if .IsAuthenticated}}
        <a href="/user/profile?id={{.AuthenticatedUser.ID}}" class="flex items-center gap-3 px-3 py-6 mb-4 no-underline hover:bg-[#3b4252] rounded-md transition-all">
            <div class="w-10 h-10 rounded-full bg-surface-container-high border border-outline-variant/30 flex items-center justify-center overflow-hidden">
                {{if .AuthenticatedUser.ProfilePicture}}
                    <img src="{{.AuthenticatedUser.ProfilePicture}}" alt="{{.AuthenticatedUser.Username}}" class="w-full h-full object-cover">
                {{else}}
                    <span class="material-symbols-outlined text-tertiary">person</span>
                {{end}}
            </div>
            <div>
                <p class="font-headline text-on-surface font-bold leading-none text-ellipsis overflow-hidden">{{.AuthenticatedUser.Username}}</p>
                <p class="font-label text-xs text-on-surface-variant mt-1 uppercase tracking-widest">Scholar Archivist</p>
            </div>
        </a>
        {{end}}
    </aside>

    <!-- Mobile Sidebar (slide-in, visible below lg) -->
    <aside id="mobile-sidebar" class="mobile-sidebar h-full w-64 fixed left-0 top-0 pt-20 flex flex-col p-4 space-y-2 sidebar-bg z-50 lg:hidden overflow-y-auto">
        {{if .IsAuthenticated}}
        <a href="/user/profile?id={{.AuthenticatedUser.ID}}" class="flex items-center gap-3 px-3 py-6 mb-4 no-underline hover:bg-[#3b4252] rounded-md transition-all" onclick="closeMobileSidebar()">
            <div class="w-10 h-10 rounded-full bg-surface-container-high border border-outline-variant/30 flex items-center justify-center overflow-hidden">
                {{if .AuthenticatedUser.ProfilePicture}}
                    <img src="{{.AuthenticatedUser.ProfilePicture}}" alt="{{.AuthenticatedUser.Username}}" class="w-full h-full object-cover">
                {{else}}
                    <span class="material-symbols-outlined text-tertiary">person</span>
                {{end}}
            </div>
            <div>
                <p class="font-headline text-on-surface font-bold leading-none text-ellipsis overflow-hidden">{{.AuthenticatedUser.Username}}</p>
                <p class="font-label text-xs text-on-surface-variant mt-1 uppercase tracking-widest">Scholar Archivist</p>
            </div>
        </a>
        {{end}}
    </aside>

    <!-- Main Content Canvas -->
    <main class="flex-1 lg:ml-64 pt-12 pb-12 px-4 md:px-12 max-w-7xl mx-auto w-full">
        <!-- Profile Header Section -->
        <header class="relative mb-12 rounded-xl overflow-hidden glass-panel border border-outline-variant/15 p-8 md:p-12">
            <div class="absolute top-0 right-0 w-64 h-64 bg-primary/5 rounded-full blur-[80px] -mr-32 -mt-32"></div>
            <div class="relative flex flex-col md:flex-row items-center gap-8">
                <div class="relative">
                    <div class="w-32 h-32 md:w-40 md:h-40 rounded-full border-4 border-surface-container-highest bg-surface-container-high flex flex-col items-center justify-center overflow-hidden shadow-2xl">
                        {{if .User.ProfilePicture}}
                            <img src="{{.User.ProfilePicture}}" alt="Profile Picture" class="w-full h-full object-cover">
                        {{else}}
                            <span class="material-symbols-outlined text-6xl text-on-surface-variant">account_circle</span>
                        {{end}}
                    </div>
                </div>
                <div class="text-center md:text-left flex-grow">
                    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
                        <div>
                            <h1 class="text-5xl md:text-6xl font-headline font-bold text-on-surface mb-2 tracking-tight">{{.User.Username}}</h1>
                            <div class="flex items-center justify-center md:justify-start gap-3 text-on-surface-variant">
                                <span class="material-symbols-outlined text-lg">calendar_today</span>
                                <span class="font-body text-sm uppercase tracking-widest font-semibold">Archivist since {{.User.CreatedAt}}</span>
                            </div>
                        </div>
                        {{if and .IsAuthenticated (eq .User.ID .AuthenticatedUser.ID)}}
                            <!-- Only show Edit button if viewing own profile -->
                            <a href="/user/profile/edit" class="inline-flex items-center gap-2 px-6 py-2.5 bg-secondary-container text-on-secondary-container rounded-md font-bold hover:brightness-110 transition-all no-underline shadow-lg border border-outline-variant/10">
                                <span class="material-symbols-outlined text-lg">edit</span>
                                <span>Edit Profile</span>
                            </a>
                        {{end}}
                    </div>
                    
                    {{if .User.AboutMe}}
                    <div class="mt-8 p-6 bg-surface-container-lowest/30 rounded-lg border border-outline-variant/5">
                        <p class="font-body text-on-surface-variant leading-relaxed italic text-lg">
                            "{{.User.AboutMe}}"
                        </p>
                    </div>
                    {{end}}
                </div>
            </div>
        </header>

        <!-- User Content Feed -->
        <section class="max-w-4xl mx-auto">
            <div class="flex items-center justify-between mb-8 text-on-surface border-b border-outline-variant/10 pb-4">
                <h2 class="text-3xl font-headline font-bold">Published Thought</h2>
                <div class="flex gap-2">
                    <span class="px-4 py-1.5 rounded-full bg-primary-container text-primary text-xs font-bold tracking-wider">{{len .Posts}} POSTS</span>
                </div>
            </div>

            <div class="space-y-6">
                {{if not .Posts}}
                <div class="text-center py-16">
                    <span class="material-symbols-outlined text-4xl text-outline-variant/50 mb-4">history_edu</span>
                    <p class="font-headline text-2xl text-on-surface-variant">This scholar's archive remains blank.</p>
                </div>
                {{end}}

                {{range .Posts}}
                <article class="p-8 rounded-xl bg-surface-container border border-outline-variant/10 hover:border-primary/20 transition-all duration-300 shadow-md">
                    <div class="flex items-center gap-4 mb-4">
                        <span class="text-xs text-on-surface-variant">{{.CreatedAt.Format "Jan 02, 2006"}}</span>
                    </div>
                    
                    <a href="/post/view?id={{.ID}}" class="no-underline block group-hover:brightness-110 transition-all">
                        <h3 class="text-2xl font-headline font-bold text-on-surface mb-4 leading-tight hover:text-primary transition-colors">{{.Title}}</h3>
                        <p class="text-on-surface-variant font-body leading-relaxed mb-6 line-clamp-3">
                            {{.Content}}
                        </p>
                    </a>
                    
                    <div class="flex items-center justify-between border-t border-outline-variant/10 pt-6">
                        <div class="flex items-center gap-6">
                            <div class="flex items-center gap-2 text-primary">
                                <span class="material-symbols-outlined text-xl">thumb_up</span>
                                <span class="text-sm font-bold">{{.Likes}}</span>
                            </div>
                            <div class="flex items-center gap-2 text-error">
                                <span class="material-symbols-outlined text-xl">thumb_down</span>
                                <span class="text-sm font-bold">{{.Dislikes}}</span>
                            </div>
                            <div class="flex items-center gap-2 text-on-surface-variant">
                                <span class="material-symbols-outlined text-xl">chat_bubble</span>
                                <span class="text-sm font-bold">{{.CommentCount}}</span>
                            </div>
                        </div>
                        <a href="/post/view?id={{.ID}}" class="text-sm font-bold text-primary uppercase tracking-wider hover:underline no-underline">View Record</a>
                    </div>
                </article>
                {{end}}
            </div>
        </section>
    </main>
</div>
{{end}}
