{{template "base" .}}

{{define "main"}}
<div class="flex min-h-screen pt-20 w-full">
    <!-- SideNavBar Component -->
    <aside class="h-full w-64 fixed left-0 top-0 pt-20 flex flex-col p-4 space-y-2 sidebar-bg z-40 hidden lg:flex overflow-y-auto">
        {{if .IsAuthenticated}}
        <a href="/user/profile?id={{.AuthenticatedUser.ID}}" class="flex items-center gap-3 px-3 py-6 mb-4 no-underline hover:bg-[#3b4252] rounded-md transition-all">
            <div class="w-10 h-10 rounded-full bg-surface-container-high border border-outline-variant/30 flex items-center justify-center overflow-hidden">
                {{if .AuthenticatedUser.ProfilePicture}}
                    <img src="{{.AuthenticatedUser.ProfilePicture}}" alt="{{.AuthenticatedUser.Username}}" class="w-full h-full object-cover">
                {{else}}
                    <span class="material-symbols-outlined text-tertiary">person</span>
                {{end}}
            </div>
            <div>
                <p class="font-headline text-on-surface font-bold leading-none text-ellipsis overflow-hidden">{{.AuthenticatedUser.Username}}</p>
                <p class="font-label text-xs text-on-surface-variant mt-1 uppercase tracking-widest">Scholar Archivist</p>
            </div>
        </a>

        <!-- Navigation Links -->
        <a href="/" class="flex items-center gap-3 px-3 py-2.5 no-underline hover:bg-[#3b4252] rounded-md transition-all text-on-surface-variant hover:text-on-surface">
            <span class="material-symbols-outlined text-xl">home</span>
            <span class="font-body text-sm font-semibold">Home</span>
        </a>
        <a href="/messages" class="flex items-center gap-3 px-3 py-2.5 no-underline hover:bg-[#3b4252] rounded-md transition-all text-primary">
            <span class="material-symbols-outlined text-xl">mail</span>
            <span class="font-body text-sm font-semibold">Inbox</span>
            {{if gt .UnreadCount 0}}
            <span class="ml-auto px-2 py-0.5 text-xs font-bold bg-error text-white rounded-full">{{.UnreadCount}}</span>
            {{end}}
        </a>
        {{end}}
    </aside>

    <!-- Mobile Sidebar -->
    <aside id="mobile-sidebar" class="mobile-sidebar h-full w-64 fixed left-0 top-0 pt-20 flex flex-col p-4 space-y-2 sidebar-bg z-50 lg:hidden overflow-y-auto">
        {{if .IsAuthenticated}}
        <a href="/messages" class="flex items-center gap-3 px-3 py-2.5 no-underline hover:bg-[#3b4252] rounded-md transition-all text-primary" onclick="closeMobileSidebar()">
            <span class="material-symbols-outlined text-xl">arrow_back</span>
            <span class="font-body text-sm font-semibold">Back to Inbox</span>
        </a>
        {{end}}
    </aside>

    <!-- Main Content -->
    <main class="flex-1 lg:ml-64 pt-4 pb-4 px-4 md:px-12 max-w-4xl mx-auto w-full flex flex-col" style="height: calc(100vh - 5rem);">

        <!-- Conversation Header -->
        <div class="flex items-center gap-4 pb-4 border-b border-outline-variant/15 mb-4 flex-shrink-0">
            <a href="/messages" class="flex items-center gap-1 text-on-surface-variant hover:text-primary transition-colors no-underline">
                <span class="material-symbols-outlined text-xl">arrow_back</span>
            </a>
            <div class="w-10 h-10 rounded-full bg-surface-container-high border border-outline-variant/30 flex items-center justify-center">
                <span class="material-symbols-outlined text-xl text-on-surface-variant">person</span>
            </div>
            <div class="flex-1">
                <a href="/user/profile?id={{.OtherUser.ID}}" class="font-headline font-bold text-on-surface text-lg no-underline hover:text-primary transition-colors">{{.OtherUser.Username}}</a>
                <p class="font-label text-xs text-on-surface-variant uppercase tracking-widest">Private Conversation</p>
            </div>
        </div>

        <!-- Message Thread (scrollable) -->
        <div id="message-thread" class="flex-1 overflow-y-auto space-y-4 pr-2 mb-4">
            {{if not .Messages}}
            <div class="text-center py-16">
                <span class="material-symbols-outlined text-4xl text-outline-variant/40 mb-4 block">chat</span>
                <p class="font-headline text-xl text-on-surface-variant">Start a conversation with {{.OtherUser.Username}}</p>
                <p class="font-body text-sm text-on-surface-variant/60 mt-2">Send the first message below.</p>
            </div>
            {{end}}

            {{range .Messages}}
            <div class="flex {{if eq .SenderID $.AuthenticatedUser.ID}}justify-end{{else}}justify-start{{end}}">
                <div class="max-w-[75%] {{if eq .SenderID $.AuthenticatedUser.ID}}bg-primary/15 border-primary/20{{else}}bg-surface-container border-outline-variant/15{{end}} border rounded-2xl px-5 py-3 shadow-sm">
                    <p class="font-body text-on-surface text-sm leading-relaxed whitespace-pre-wrap">{{.Content}}</p>
                    <div class="flex items-center justify-end gap-2 mt-2">
                        <span class="font-label text-[10px] text-on-surface-variant/60">{{.CreatedAt.Format "Jan 02, 15:04"}}</span>
                        {{if eq .SenderID $.AuthenticatedUser.ID}}
                            {{if .IsRead}}
                            <span class="material-symbols-outlined text-primary text-xs" style="font-size:14px">done_all</span>
                            {{else}}
                            <span class="material-symbols-outlined text-on-surface-variant/40 text-xs" style="font-size:14px">done</span>
                            {{end}}
                        {{end}}
                    </div>
                </div>
            </div>
            {{end}}
        </div>

        <!-- Compose Bar (pinned to bottom) -->
        <form action="/messages/send" method="POST" class="flex gap-3 items-end pt-4 border-t border-outline-variant/15 flex-shrink-0">
            <input type="hidden" name="receiver_id" value="{{.OtherUser.ID}}">
            <div class="flex-1 relative">
                <textarea name="content" rows="1" required placeholder="Write a message..." 
                    class="w-full bg-surface-container border border-outline-variant/20 rounded-xl px-4 py-3 text-on-surface font-body text-sm resize-none focus:outline-none focus:border-primary/40 focus:ring-1 focus:ring-primary/20 transition-all placeholder:text-on-surface-variant/40"
                    oninput="this.style.height='auto'; this.style.height=Math.min(this.scrollHeight, 120)+'px';"
                    onkeydown="if(event.key==='Enter' && !event.shiftKey){event.preventDefault(); this.closest('form').submit();}"></textarea>
            </div>
            <button type="submit" class="flex-shrink-0 w-11 h-11 rounded-xl bg-primary text-on-primary flex items-center justify-center hover:opacity-90 active:scale-95 transition-all shadow-lg">
                <span class="material-symbols-outlined text-xl">send</span>
            </button>
        </form>
    </main>
</div>

<script>
    // Auto-scroll to the latest message
    (function() {
        var thread = document.getElementById('message-thread');
        if (thread) { thread.scrollTop = thread.scrollHeight; }
    })();
</script>
{{end}}
