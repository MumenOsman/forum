{{template "base" .}}

{{define "main"}}
<div class="flex min-h-screen pt-20 w-full">
    <!-- SideNavBar: Conversation Contacts -->
    <aside class="h-full w-72 fixed left-0 top-0 pt-20 flex flex-col sidebar-bg z-40 hidden lg:flex overflow-y-auto">
        {{if .IsAuthenticated}}
        <!-- Profile link -->
        <a href="/user/profile?id={{.AuthenticatedUser.ID}}" class="flex items-center gap-3 px-4 py-5 mb-2 no-underline hover:bg-[#3b4252] transition-all border-b border-outline-variant/10">
            <div class="w-10 h-10 rounded-full bg-surface-container-high border border-outline-variant/30 flex items-center justify-center overflow-hidden flex-shrink-0">
                {{if .AuthenticatedUser.ProfilePicture}}
                    <img src="{{.AuthenticatedUser.ProfilePicture}}" alt="{{.AuthenticatedUser.Username}}" class="w-full h-full object-cover">
                {{else}}
                    <span class="material-symbols-outlined text-tertiary">person</span>
                {{end}}
            </div>
            <div class="min-w-0">
                <p class="font-headline text-on-surface font-bold leading-none truncate">{{.AuthenticatedUser.Username}}</p>
                <p class="font-label text-xs text-on-surface-variant mt-1 uppercase tracking-widest">Messages</p>
            </div>
        </a>

        <!-- Conversations list -->
        <div class="flex-1 overflow-y-auto">
            {{if .Conversations}}
            {{range .Conversations}}
            <a href="/messages/conversation?with={{.OtherUserID}}"
               class="flex items-center gap-3 px-4 py-3 no-underline hover:bg-[#3b4252] transition-all group
                      {{if eq .OtherUserID $.OtherUser.ID}}bg-primary/10 border-r-2 border-r-primary{{end}}">
                <div class="w-9 h-9 rounded-full bg-surface-container-high border border-outline-variant/20 flex items-center justify-center flex-shrink-0">
                    <span class="material-symbols-outlined text-lg text-on-surface-variant">person</span>
                </div>
                <div class="flex-1 min-w-0">
                    <div class="flex items-center justify-between gap-1">
                        <span class="font-body text-sm font-bold truncate group-hover:text-primary transition-colors
                                     {{if eq .OtherUserID $.OtherUser.ID}}text-primary{{else}}text-on-surface{{end}}">{{.OtherUsername}}</span>
                        <span class="font-label text-[10px] text-on-surface-variant flex-shrink-0">{{.LastMessageTime.Format "15:04"}}</span>
                    </div>
                    <p class="font-body text-xs text-on-surface-variant truncate mt-0.5">
                        {{if .IsSenderOfLast}}<span class="text-primary">You:</span> {{end}}{{.LastMessage}}
                    </p>
                </div>
                {{if gt .UnreadCount 0}}
                <span class="flex-shrink-0 w-5 h-5 rounded-full bg-primary text-on-primary text-[10px] font-bold flex items-center justify-center">{{.UnreadCount}}</span>
                {{end}}
            </a>
            {{end}}
            {{else}}
            <div class="px-4 py-8 text-center">
                <span class="material-symbols-outlined text-2xl text-outline-variant/40 mb-2 block">forum</span>
                <p class="font-body text-xs text-on-surface-variant/60">No other conversations</p>
            </div>
            {{end}}
        </div>

        <!-- Back to Home link at bottom -->
        <a href="/" class="flex items-center gap-3 px-4 py-3 no-underline hover:bg-[#3b4252] transition-all text-on-surface-variant hover:text-on-surface border-t border-outline-variant/10">
            <span class="material-symbols-outlined text-lg">arrow_back</span>
            <span class="font-body text-xs font-semibold uppercase tracking-wider">Back to Forum</span>
        </a>
        {{end}}
    </aside>

    <!-- Mobile Sidebar -->
    <aside id="mobile-sidebar" class="mobile-sidebar h-full w-72 fixed left-0 top-0 pt-20 flex flex-col sidebar-bg z-50 lg:hidden overflow-y-auto">
        {{if .IsAuthenticated}}
        <div class="px-4 py-3 border-b border-outline-variant/10">
            <p class="font-headline text-on-surface font-bold text-sm">Conversations</p>
        </div>
        <div class="flex-1 overflow-y-auto">
            {{range .Conversations}}
            <a href="/messages/conversation?with={{.OtherUserID}}"
               class="flex items-center gap-3 px-4 py-3 no-underline hover:bg-[#3b4252] transition-all
                      {{if eq .OtherUserID $.OtherUser.ID}}bg-primary/10{{end}}"
               onclick="closeMobileSidebar()">
                <div class="w-9 h-9 rounded-full bg-surface-container-high border border-outline-variant/20 flex items-center justify-center flex-shrink-0">
                    <span class="material-symbols-outlined text-lg text-on-surface-variant">person</span>
                </div>
                <div class="flex-1 min-w-0">
                    <span class="font-body text-sm font-bold truncate
                                 {{if eq .OtherUserID $.OtherUser.ID}}text-primary{{else}}text-on-surface{{end}}">{{.OtherUsername}}</span>
                    <p class="font-body text-xs text-on-surface-variant truncate mt-0.5">
                        {{if .IsSenderOfLast}}<span class="text-primary">You:</span> {{end}}{{.LastMessage}}
                    </p>
                </div>
                {{if gt .UnreadCount 0}}
                <span class="flex-shrink-0 w-5 h-5 rounded-full bg-primary text-on-primary text-[10px] font-bold flex items-center justify-center">{{.UnreadCount}}</span>
                {{end}}
            </a>
            {{end}}
        </div>
        <a href="/" class="flex items-center gap-3 px-4 py-3 no-underline hover:bg-[#3b4252] transition-all text-on-surface-variant border-t border-outline-variant/10" onclick="closeMobileSidebar()">
            <span class="material-symbols-outlined text-lg">arrow_back</span>
            <span class="font-body text-xs font-semibold uppercase tracking-wider">Back to Forum</span>
        </a>
        {{end}}
    </aside>

    <!-- Main Content -->
    <main class="flex-1 lg:ml-72 pt-4 pb-4 px-4 md:px-12 max-w-4xl mx-auto w-full flex flex-col" style="height: calc(100vh - 5rem);">

        <!-- Conversation Header -->
        <div class="flex items-center gap-4 pb-4 border-b border-outline-variant/15 mb-4 flex-shrink-0">
            <a href="/messages" class="flex items-center gap-1 text-on-surface-variant hover:text-primary transition-colors no-underline">
                <span class="material-symbols-outlined text-xl">arrow_back</span>
            </a>
            <div class="w-10 h-10 rounded-full bg-surface-container-high border border-outline-variant/30 flex items-center justify-center">
                <span class="material-symbols-outlined text-xl text-on-surface-variant">person</span>
            </div>
            <div class="flex-1">
                <a href="/user/profile?id={{.OtherUser.ID}}" class="font-headline font-bold text-on-surface text-lg no-underline hover:text-primary transition-colors">{{.OtherUser.Username}}</a>
                <p class="font-label text-xs text-on-surface-variant uppercase tracking-widest">Private Conversation</p>
            </div>
        </div>

        <!-- Message Thread (scrollable) -->
        <div id="message-thread" class="flex-1 overflow-y-auto space-y-4 pr-2 mb-4">
            {{if not .Messages}}
            <div class="text-center py-16">
                <span class="material-symbols-outlined text-4xl text-outline-variant/40 mb-4 block">chat</span>
                <p class="font-headline text-xl text-on-surface-variant">Start a conversation with {{.OtherUser.Username}}</p>
                <p class="font-body text-sm text-on-surface-variant/60 mt-2">Send the first message below.</p>
            </div>
            {{end}}

            {{range .Messages}}
            <div class="flex {{if eq .SenderID $.AuthenticatedUser.ID}}justify-end{{else}}justify-start{{end}}">
                <div class="max-w-[75%] {{if eq .SenderID $.AuthenticatedUser.ID}}bg-primary/15 border-primary/20{{else}}bg-surface-container border-outline-variant/15{{end}} border rounded-2xl px-5 py-3 shadow-sm">
                    <p class="font-body text-on-surface text-sm leading-relaxed whitespace-pre-wrap">{{.Content}}</p>
                    <div class="flex items-center justify-end gap-2 mt-2">
                        <span class="font-label text-[10px] text-on-surface-variant/60">{{.CreatedAt.Format "Jan 02, 15:04"}}</span>
                        {{if eq .SenderID $.AuthenticatedUser.ID}}
                            {{if .IsRead}}
                            <span class="material-symbols-outlined text-primary text-xs" style="font-size:14px">done_all</span>
                            {{else}}
                            <span class="material-symbols-outlined text-on-surface-variant/40 text-xs" style="font-size:14px">done</span>
                            {{end}}
                        {{end}}
                    </div>
                </div>
            </div>
            {{end}}
        </div>

        <!-- Compose Bar (pinned to bottom) -->
        <form action="/messages/send" method="POST" class="flex gap-3 items-end pt-4 border-t border-outline-variant/15 flex-shrink-0">
            <input type="hidden" name="receiver_id" value="{{.OtherUser.ID}}">
            <div class="flex-1 relative">
                <textarea name="content" rows="1" required placeholder="Write a message..."
                    class="w-full bg-surface-container border border-outline-variant/20 rounded-xl px-4 py-3 text-on-surface font-body text-sm resize-none focus:outline-none focus:border-primary/40 focus:ring-1 focus:ring-primary/20 transition-all placeholder:text-on-surface-variant/40"
                    oninput="this.style.height='auto'; this.style.height=Math.min(this.scrollHeight, 120)+'px';"
                    onkeydown="if(event.key==='Enter' && !event.shiftKey){event.preventDefault(); this.closest('form').submit();}"></textarea>
            </div>
            <button type="submit" class="flex-shrink-0 w-11 h-11 rounded-xl bg-primary text-on-primary flex items-center justify-center hover:opacity-90 active:scale-95 transition-all shadow-lg">
                <span class="material-symbols-outlined text-xl">send</span>
            </button>
        </form>
    </main>
</div>

<script>
    // Auto-scroll to the latest message
    (function() {
        var thread = document.getElementById('message-thread');
        if (thread) { thread.scrollTop = thread.scrollHeight; }
    })();
</script>
{{end}}
