{{template "base" .}}

{{define "main"}}
<div class="flex min-h-screen pt-20 w-full">
    <!-- SideNavBar Component -->
    <aside class="h-full w-64 fixed left-0 top-0 pt-20 flex flex-col p-4 space-y-2 bg-[#131b2e] border-r border-[#dae2fd]/10 z-40 hidden lg:flex overflow-y-auto">
        {{if .IsAuthenticated}}
        <div class="flex items-center gap-3 px-3 py-6 mb-4">
            <div class="w-10 h-10 rounded-full bg-surface-container-high border border-outline-variant/30 flex items-center justify-center overflow-hidden">
                {{if .AuthenticatedUser.ProfilePicture}}
                    <img src="{{.AuthenticatedUser.ProfilePicture}}" alt="{{.AuthenticatedUser.Username}}" class="w-full h-full object-cover">
                {{else}}
                    <span class="material-symbols-outlined text-tertiary">person</span>
                {{end}}
            </div>
            <div>
                <p class="font-headline text-on-surface font-bold leading-none text-ellipsis overflow-hidden">{{.AuthenticatedUser.Username}}</p>
                <p class="font-label text-xs text-on-surface-variant mt-1 uppercase tracking-widest">Scholar Archivist</p>
            </div>
        </div>
        {{end}}

        <form action="/" method="GET" class="px-2 mb-4 mt-2">
            <div class="relative group">
                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant/50 group-focus-within:text-primary transition-colors text-sm">search</span>
                <input type="text" name="q" placeholder="Search archive..." value="{{.SearchQuery}}" class="w-full bg-[#171f33] border border-outline-variant/20 rounded-md py-2 pl-9 pr-3 text-sm text-on-surface font-label focus:outline-none focus:border-primary/50 transition-colors placeholder:text-on-surface-variant/40">
            </div>
        </form>
        
        <nav class="flex-1 space-y-1">
            <form action="/" method="GET" class="m-0">
                {{if .SearchQuery}}<input type="hidden" name="q" value="{{.SearchQuery}}">{{end}}
                <button type="submit" name="category" value="" class="w-full flex items-center gap-3 px-4 py-3 {{if and (not .FilterCategory) (not .FilterAuthored) (not .FilterLiked)}}text-[#fabd00] bg-[#171f33]{{else}}text-[#dae2fd]/60 hover:text-[#dae2fd] hover:bg-[#171f33]{{end}} transition-transform duration-200 hover:translate-x-1 rounded-md cursor-pointer border-none bg-transparent">
                    <span class="material-symbols-outlined">menu_book</span>
                    <span class="font-label">All Categories</span>
                </button>
            </form>

            {{if .IsAuthenticated}}
            <form action="/" method="GET" class="m-0">
                <input type="hidden" name="authored" value="true">
                <button type="submit" class="w-full flex items-center gap-3 px-4 py-3 {{if .FilterAuthored}}text-[#fabd00] bg-[#171f33]{{else}}text-[#dae2fd]/60 hover:text-[#dae2fd] hover:bg-[#171f33]{{end}} transition-transform duration-200 hover:translate-x-1 rounded-md cursor-pointer border-none bg-transparent">
                    <span class="material-symbols-outlined">person_pin</span>
                    <span class="font-label">My Posts</span>
                </button>
            </form>
            <form action="/" method="GET" class="m-0">
                <input type="hidden" name="liked" value="true">
                <button type="submit" class="w-full flex items-center gap-3 px-4 py-3 {{if .FilterLiked}}text-[#fabd00] bg-[#171f33]{{else}}text-[#dae2fd]/60 hover:text-[#dae2fd] hover:bg-[#171f33]{{end}} transition-transform duration-200 hover:translate-x-1 rounded-md cursor-pointer border-none bg-transparent">
                    <span class="material-symbols-outlined">favorite</span>
                    <span class="font-label">Liked Posts</span>
                </button>
            </form>
            {{end}}

            {{range .Categories}}
            <form action="/" method="GET" class="m-0">
                {{if $.SearchQuery}}<input type="hidden" name="q" value="{{$.SearchQuery}}">{{end}}
                <button type="submit" name="category" value="{{.ID}}" class="w-full flex items-center gap-3 px-4 py-3 {{if eq $.FilterCategory (printf "%d" .ID)}}text-[#fabd00] bg-[#171f33]{{else}}text-[#dae2fd]/60 hover:text-[#dae2fd] hover:bg-[#171f33]{{end}} transition-transform duration-200 hover:translate-x-1 rounded-md cursor-pointer border-none bg-transparent">
                    <span class="material-symbols-outlined">auto_stories</span>
                    <span class="font-label">{{.Name}}</span>
                </button>
            </form>
            {{end}}
        </nav>
        
    </aside>

    <!-- Main Content -->
    <main class="lg:ml-64 pt-24 pb-20 px-4 md:px-8 lg:px-12 max-w-6xl mx-auto w-full">
        <!-- Post Header -->
        <article class="relative">
            <header class="mb-12">
                <nav class="flex items-center gap-2 mb-8 text-on-surface-variant font-label text-xs uppercase tracking-widest">
                    <a class="hover:text-primary transition-colors no-underline text-on-surface-variant group-hover:text-primary" href="/">Archive</a>
                    <span class="material-symbols-outlined text-xs">chevron_right</span>
                    <span class="text-tertiary">Reading Room</span>
                </nav>
                <h1 class="font-headline text-4xl md:text-6xl lg:text-7xl leading-tight text-on-surface mb-8 italic">
                    {{.Post.Title}}
                </h1>
                <div class="flex flex-wrap items-center justify-between gap-6 border-y border-white/10 py-6">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-xl border border-primary/20 bg-surface-container-high flex items-center justify-center overflow-hidden">
                            <span class="material-symbols-outlined text-primary text-2xl">person</span>
                        </div>
                        <div>
                            <a href="/user/profile?id={{.Post.UserID}}" class="no-underline text-on-surface hover:text-primary transition-colors">
                                <p class="font-headline text-lg leading-none">{{.Post.Username}}</p>
                            </a>
                            <span class="font-label text-xs uppercase tracking-tighter text-tertiary">Literary Fellow</span>
                        </div>
                    </div>
                    <div class="flex items-center gap-8 font-label text-xs uppercase tracking-widest text-on-surface-variant">
                        <div class="flex flex-col">
                            <span class="text-[10px] text-on-surface-variant/50">Published</span>
                            <span>{{.Post.CreatedAt.Format "Jan 02, 2006"}}</span>
                        </div>
                    </div>
                </div>
            </header>
            
            <!-- Article Body -->
            <section class="font-headline text-xl leading-relaxed text-on-surface/90 space-y-8 max-w-3xl whitespace-pre-wrap">
                <p class="first-letter:text-7xl first-letter:font-headline first-letter:mr-3 first-letter:float-left first-letter:text-primary">{{.Post.Content}}</p>
            </section>
            
            <!-- Social Interactions -->
            <footer class="mt-16 flex flex-wrap items-center justify-between gap-6 border-t border-white/10 pt-12">
                <div class="flex items-center gap-4">
                    <div class="flex items-center bg-surface-container rounded-md overflow-hidden p-1 shadow-inner">
                        <form action="/vote" method="POST" class="m-0 border-none">
                            <input type="hidden" name="target_id" value="{{.Post.ID}}">
                            <input type="hidden" name="target_type" value="post">
                            <input type="hidden" name="vote_type" value="1">
                            <button class="flex items-center gap-2 px-4 py-2 hover:bg-surface-container-high text-primary transition-colors group bg-transparent border-none cursor-pointer active:scale-95">
                                <span class="material-symbols-outlined text-xl group-hover:scale-110 transition-transform">thumb_up</span>
                                <span class="font-label text-sm font-bold">{{.Post.Likes}}</span>
                            </button>
                        </form>
                        <div class="w-[1px] h-6 bg-white/10"></div>
                        <form action="/vote" method="POST" class="m-0 border-none">
                            <input type="hidden" name="target_id" value="{{.Post.ID}}">
                            <input type="hidden" name="target_type" value="post">
                            <input type="hidden" name="vote_type" value="-1">
                            <button class="flex items-center gap-2 px-4 py-2 hover:bg-surface-container-high text-on-surface-variant hover:text-error transition-colors group bg-transparent border-none cursor-pointer active:scale-95">
                                <span class="material-symbols-outlined text-xl group-hover:scale-110 transition-transform">thumb_down</span>
                                <span class="font-label text-sm font-bold">{{.Post.Dislikes}}</span>
                            </button>
                        </form>
                    </div>
                </div>
            </footer>
        </article>

        <!-- Discussion Section -->
        <section class="mt-24 max-w-3xl">
            <header class="flex items-center justify-between mb-12">
                <h2 class="font-headline text-3xl italic text-on-surface">The Discussion</h2>
                <span class="bg-primary-container text-primary px-3 py-1 rounded-full font-label text-xs font-bold">{{len .Comments}} Comments</span>
            </header>

            <!-- Comments List -->
            <div class="space-y-1">
                {{range .Comments}}
                <div class="p-8 bg-surface-container-low transition-colors hover:bg-surface-container border-l-2 {{if eq .UserID $.Post.UserID}}border-tertiary{{else}}border-transparent{{end}}">
                    <div class="flex gap-6">
                        <div class="w-10 h-10 rounded-lg bg-surface-container-high border border-outline-variant/30 flex items-center justify-center text-primary font-bold">
                            <span class="material-symbols-outlined text-sm">person</span>
                        </div>
                        <div class="flex-1">
                            <div class="flex items-center justify-between mb-4">
                                <div>
                                    <span class="font-headline text-lg text-on-surface">{{.Username}} </span>
                                    {{if eq .UserID $.Post.UserID}}
                                        <span class="bg-primary/10 text-primary text-[10px] font-bold px-2 py-0.5 rounded-full border border-primary/20 ml-2 uppercase tracking-tighter">Author</span>
                                    {{end}}
                                    <span class="text-xs text-on-surface-variant/50 ml-3 font-label uppercase tracking-widest">{{.CreatedAt.Format "Jan 02, 2006"}}</span>
                                </div>
                            </div>
                            <p class="font-body text-on-surface-variant leading-relaxed mb-6 whitespace-pre-wrap">{{.Content}}</p>
                            
                            <div class="flex items-center gap-6">
                                <div class="flex items-center gap-4">
                                    <form action="/vote" method="POST" class="m-0 border-none">
                                        <input type="hidden" name="target_id" value="{{.ID}}">
                                        <input type="hidden" name="target_type" value="comment">
                                        <input type="hidden" name="vote_type" value="1">
                                        <button class="flex items-center gap-1.5 text-on-surface-variant hover:text-primary transition-colors group bg-transparent border-none cursor-pointer active:scale-95">
                                            <span class="material-symbols-outlined text-base group-hover:scale-110 transition-transform">keyboard_arrow_up</span>
                                            <span class="font-label text-xs font-bold uppercase">{{.Likes}}</span>
                                        </button>
                                    </form>
                                    <form action="/vote" method="POST" class="m-0 border-none">
                                        <input type="hidden" name="target_id" value="{{.ID}}">
                                        <input type="hidden" name="target_type" value="comment">
                                        <input type="hidden" name="vote_type" value="-1">
                                        <button class="flex items-center gap-1.5 text-on-surface-variant hover:text-error transition-colors group bg-transparent border-none cursor-pointer active:scale-95">
                                            <span class="material-symbols-outlined text-base group-hover:scale-110 transition-transform">keyboard_arrow_down</span>
                                            <span class="font-label text-xs font-bold uppercase">{{.Dislikes}}</span>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                {{end}}
            </div>

            <!-- Comment Form -->
            {{if .IsAuthenticated}}
            <div class="mt-16 p-8 bg-surface-container-high rounded-xl border border-white/5 shadow-2xl relative overflow-hidden">
                <div class="absolute top-0 right-0 p-8 opacity-5">
                    <span class="material-symbols-outlined text-9xl">auto_stories</span>
                </div>
                <h3 class="font-headline text-2xl mb-6 italic text-on-surface">Add to the Archive</h3>
                
                {{if .ErrorMessage}}
                    <div class="px-6 py-4 mb-4 rounded bg-error/20 border-l-4 border-error text-error font-bold text-sm">
                        {{.ErrorMessage}}
                    </div>
                {{end}}

                <form action="/comment/create" method="POST" class="space-y-6 relative z-10 m-0 border-none">
                    <input type="hidden" name="post_id" value="{{.Post.ID}}">
                    <div class="group">
                        <textarea class="w-full bg-transparent border-0 border-b border-outline-variant focus:ring-0 focus:border-primary text-on-surface font-body text-lg placeholder:text-on-surface-variant/30 py-4 transition-all resize-y" name="content" placeholder="Contribute your thoughts to the collection..." rows="4" required></textarea>
                    </div>
                    <div class="flex items-center justify-between">
                        <div class="flex items-center gap-2 text-on-surface-variant/50">
                            <span class="material-symbols-outlined text-sm">info</span>
                            <span class="font-label text-[10px] uppercase tracking-widest">Archive Record</span>
                        </div>
                        <button class="bg-primary hover:bg-surface-tint text-on-primary font-label text-xs font-bold uppercase tracking-widest px-8 py-3 rounded-md transition-all active:scale-95 flex items-center gap-2 border-none cursor-pointer" type="submit">
                            <span>Post Comment</span>
                            <span class="material-symbols-outlined text-sm">send</span>
                        </button>
                    </div>
                </form>
            </div>
            {{else}}
            <div class="mt-16 bg-surface-container border border-outline-variant/20 rounded-xl p-8 shadow-xl text-center">
                <span class="material-symbols-outlined text-4xl text-outline-variant/50 mb-4">lock_clock</span>
                <p class="font-headline text-lg text-on-surface">You must be formally recognized by the archives to contribute.</p>
                <div class="mt-6 flex justify-center gap-4">
                    <a href="/user/login" class="px-6 py-2 bg-gradient-to-br from-primary to-primary-container text-on-primary rounded-md font-bold shadow-lg no-underline hover:brightness-110">Login</a>
                    <a href="/user/signup" class="px-6 py-2 border border-outline-variant text-[#dae2fd] rounded-md font-bold shadow-lg shadow-black/20 no-underline hover:bg-surface-container-high">Register</a>
                </div>
            </div>
            {{end}}

        </section>
    </main>
</div>

<!-- Decorative Elements (From the design mockup) -->
<div class="fixed bottom-0 right-0 w-96 h-96 bg-primary/5 blur-[120px] pointer-events-none -z-10"></div>
<div class="fixed top-1/4 left-1/4 w-64 h-64 bg-tertiary/5 blur-[100px] pointer-events-none -z-10"></div>

{{end}}
