{{template "base" .}}

{{define "main"}}
<main class="relative flex-grow flex items-center justify-center px-6 pt-20 overflow-hidden min-h-screen">
    <!-- Artistic Background Accents -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden flex items-center justify-center">
        <div class="absolute -top-[10%] -left-[5%] w-[40vw] h-[40vw] bg-primary/10 rounded-full blur-[120px]"></div>
        <div class="absolute bottom-[0%] right-[0%] w-[50vw] h-[50vw] bg-tertiary/5 rounded-full blur-[150px]"></div>
    </div>

    <!-- Error Card -->
    <div class="relative z-10 max-w-2xl w-full text-center">
        <div class="bg-surface-container/40 backdrop-blur-2xl p-12 md:p-20 rounded-xl border border-outline-variant/15 shadow-[0_40px_80px_rgba(0,0,0,0.4)]">
            <!-- Large Elegant Error Code -->
            <div class="relative inline-block mb-8">
                <h1 class="font-headline text-[80px] md:text-[120px] font-extrabold leading-none tracking-tighter text-transparent bg-clip-text bg-gradient-to-b from-primary via-primary-fixed-dim to-transparent opacity-80">
                    {{if .ErrorCode}}{{.ErrorCode}}{{else}}ERROR{{end}}
                </h1>
                <div class="absolute -bottom-4 left-1/2 -translate-x-1/2 w-24 h-px bg-tertiary/40"></div>
            </div>

            <div class="space-y-6">
                <h2 class="font-headline text-3xl md:text-4xl text-on-surface">
                    It seems you've wandered into an unwritten chapter.
                </h2>
                <p class="font-body text-lg py-4 text-on-surface-variant max-w-md mx-auto leading-relaxed border-y border-outline-variant/10 text-error font-bold">
                    {{.ErrorMessage}}
                </p>
                <div class="pt-6 flex flex-col sm:flex-row items-center justify-center gap-6">
                    <a class="group flex items-center justify-center gap-3 px-8 py-4 bg-surface-tint text-on-primary rounded-md font-label font-bold text-sm tracking-widest uppercase transition-all hover:translate-y-[-2px] hover:shadow-xl active:scale-95 duration-200 no-underline" href="/">
                        <span class="material-symbols-outlined text-xl">home</span>
                        Return Home
                    </a>
                </div>
            </div>

            <!-- Subtle Decorative Element -->
            <div class="mt-16 flex justify-center opacity-30">
                <span class="material-symbols-outlined text-5xl font-thin text-tertiary">menu_book</span>
            </div>
        </div>
    </div>
</main>
{{end}}
