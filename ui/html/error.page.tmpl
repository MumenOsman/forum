{{template "base" .}}

{{define "main"}}
<div style="text-align: center; margin-top: 50px; padding: 40px; border: 1px solid #ffcccc; background-color: #ffe6e6; border-radius: 8px;">
    <h2 style="color: #d9534f; font-size: 2em; margin-bottom: 20px;">Oops! Something went wrong.</h2>
    {{if .ErrorMessage}}
        <p style="font-size: 1.25em; color: #555;">{{.ErrorMessage}}</p>
    {{else}}
        <p style="font-size: 1.25em; color: #555;">An unexpected server error occurred.</p>
    {{end}}
    <br>
    <a href="/" style="display: inline-block; margin-top: 20px; padding: 12px 25px; background-color: #d9534f; color: white; text-decoration: none; border-radius: 4px; font-weight: bold;">Return Home</a>
</div>
{{end}}
